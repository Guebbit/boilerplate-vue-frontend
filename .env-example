# App settings
VITE_APP_DEFAULT_LOCALE = en
VITE_APP_SUPPORTED_LOCALES = en,it,es
VITE_APP_PUBLIC_PATH = /
# VITE_APP_BASE_URL # createRouter.history = createWebHistory()

# API settings
VITE_APP_PORT = 8080
VITE_DOCS_PORT = 4173
VITE_API_URL = http://localhost:3000
VITE_API_WEBSOCKET = ws://localhost:3000/ws/chat
VITE_API_SSE = http://localhost:3000/observability/events
# Backend pairing tip:
# set NODE_CORS_ORIGIN=http://localhost:8080 in boilerplate-node-backend `.env`
# If true, API calls will be mocked using mock instead
VITE_API_MOCK_ENABLED = false

# Axios settings
VITE_AXIOS_TIMEOUT = 10000

# Debug settings (dev only)
VITE_APP_DEBUG_ROUTER = false
VITE_APP_DEBUG_HOME = false
VITE_APP_DEBUG_HTTP = false

# Grafana Faro settings (error/crash monitoring + FE tracing + web-vitals)
# The browser only ever talks to Grafana Alloy's Faro receiver, which fans out
# to Loki/Tempo/Prometheus. If VITE_FARO_URL is empty, Faro is disabled.
VITE_FARO_URL = http://localhost:12347/collect
VITE_FARO_APP_NAME = frontend
VITE_FARO_APP_VERSION = 1.0.0
VITE_FARO_ENVIRONMENT = local
# Note: traces are stitched onto the backend using VITE_API_URL as the origin
# the W3C `traceparent` header is propagated to.

# Umami settings (product analytics: pageviews + custom events)
# Get the website id from the Umami dashboard (Settings → Websites).
# If VITE_UMAMI_WEBSITE_ID is empty, Umami is disabled.
VITE_UMAMI_SRC = http://localhost:8090/script.js
VITE_UMAMI_WEBSITE_ID =
