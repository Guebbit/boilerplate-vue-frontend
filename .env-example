# App settings
VITE_APP_DEFAULT_LOCALE = en
VITE_APP_SUPPORTED_LOCALES = en,it,es
VITE_APP_PUBLIC_PATH = /
# VITE_APP_BASE_URL # createRouter.history = createWebHistory()

# API settings
VITE_API_URL = http://localhost:3000
VITE_API_WEBSOCKET = ws://localhost:3000/ws/chat
VITE_API_SSE = http://localhost:3000/observability/events
# Backend pairing tip:
# set NODE_CORS_ORIGIN=http://localhost:8080 in boilerplate-node-backend `.env`
# If true, API calls will be mocked using mock instead
VITE_API_MOCK_ENABLED = false

# Axios settings
VITE_AXIOS_TIMEOUT = 10000

# Debug settings (dev only)
VITE_APP_DEBUG_ROUTER = false
VITE_APP_DEBUG_HOME = false
VITE_APP_DEBUG_HTTP = false

# Sentry settings (optional)
# Sentry catches frontend errors and performance issues.
# If empty, Sentry is disabled.
VITE_SENTRY_DSN =
# 0 = no performance tracing, 1 = trace everything.
VITE_SENTRY_TRACES_SAMPLE_RATE = 0
# Session replay sample rates (0-1)
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE = 0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE = 1.0
# Enable Sentry debug mode (logs internal Sentry events to console)
VITE_SENTRY_DEBUG = false

# PostHog settings (optional)
# PostHog provides product analytics and feature flags.
# If empty, PostHog is disabled.
VITE_POSTHOG_API_KEY =
VITE_POSTHOG_API_HOST = https://app.posthog.com
# Enable PostHog debug mode (logs captured events to console)
VITE_POSTHOG_DEBUG = false
