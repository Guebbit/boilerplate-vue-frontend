{
    "extends": "./tsconfig.app.json",
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "tests/**/*.vue",
        "scripts/**/*.ts",
        "cypress.config.ts",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "compilerOptions": {
        "types": ["vue", "jest", "node"],
        "allowJs": true
    }
}
