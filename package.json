{
  "name": "boilerplate-vue-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPLv3.0",
  "scripts": {
    "dev": "vite --port 8080",
    "build": "run-p type-check-only \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check-only": "vue-tsc --build --force",
    "lint": "eslint",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:target": "vitest run src/components/atoms/__tests__/CounterInput.spec.ts",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:target": "start-server-and-test preview http://localhost:4173 'cypress run --e2e' --spec 'tests/e2e/xxxx.spec.ts'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
    "kill:gnu": "pkill -9 node",
    "format": "prettier --write src/",
    "prepublish": "npm run lint && npm run test:unit && npm run build && npm run docs:build"
  },
  "dependencies": {
    "@guebbit/css-toolkit": "1.3.2",
    "@guebbit/js-toolkit": "^1.0.3",
    "axios": "^1.12.1",
    "minisearch": "^7.1.2",
    "pinia": "^3.0.3",
    "vue": "^3.5.21",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.5.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.3.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^15.2.0",
    "eslint": "^9.35.0",
    "eslint-plugin-cypress": "^5.1.1",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.92.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.5",
    "vite-plugin-vue-devtools": "^8.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^3.0.7"
  }
}
