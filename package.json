{
    "name": "boilerplate-vue-frontend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "license": "AGPLv3.0",
    "scripts": {
        "dev": "vite --port 8080",
        "build": "run-p type-check-only \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check-only": "vue-tsc --build --force",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:openapi": "spectral lint openapi.yaml",
        "lint:openapi:fix": "spectral lint openapi.yaml --format stylish",
        "prettier": "npx prettier .",
        "prettier:check": "npx prettier --check .",
        "prettier:fix": "npx prettier . --write",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "vitest run",
        "test:unit:coverage": "vitest run --coverage",
        "test:unit:target": "vitest run tests/unit/components/atoms/CounterInput.spec.ts",
        "test:e2e": "start-server-and-test 'VITE_API_MOCK_ENABLED=true vite dev --port 4173' http://localhost:4173 'cypress run --e2e'",
        "test:e2e:target": "start-server-and-test 'VITE_API_MOCK_ENABLED=true vite dev --port 4173' http://localhost:4173 \"cypress run --e2e --spec 'tests/e2e/specs/orders.cy.ts'\"",
        "test:e2e:dev": "start-server-and-test 'VITE_API_MOCK_ENABLED=true vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "docs:asyncapi": "asyncapi start studio asyncapi.yaml",
        "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
        "kill:gnu": "pkill -9 node",
        "kill:port": "fuser -k 4173/tcp || true",
        "podman:restart": "podman compose down && podman compose up -d",
        "podman:rebuild": "podman compose down -v && podman compose build --no-cache && podman compose up -d",
        "podman:nuke": "pkill -9 -f 'podman|conmon|runc' 2>/dev/null || true; systemctl --user restart podman",
        "docker:restart": "docker compose down && docker compose up -d",
        "docker:rebuild": "docker compose down -v && docker compose build --no-cache && docker compose up -d",
        "docker:nuke": "pkill -9 -f 'dockerd|containerd-shim' 2>/dev/null || true; sudo systemctl restart docker",
        "pretest:e2e": "npm run kill:port",
        "genapi": "orval",
        "genasyncapi": "tsx scripts/gen-asyncapi-types.ts",
        "update:all": "npm-check-updates -u",
        "complete": "npm run lint:fix && npm run lint:openapi && npm run prettier:fix && npm run build && npm run test",
        "complete:check": "npm run lint && npm run lint:openapi && npm run prettier:check && npm run build && npm run test",
        "publish:public": "npm run complete && npm publish --access public",
        "prepare": "husky"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "^2.8.2",
        "@grafana/faro-web-tracing": "^2.8.2",
        "@guebbit/css-toolkit": "^1.4.1",
        "@guebbit/vue-toolkit": "^2.1.0",
        "axios": "^1.13.6",
        "lucide-vue-next": "^1.0.0",
        "pinia": "^3.0.4",
        "vue": "^3.5.29",
        "vue-i18n": "^11.3.0",
        "vue-router": "^5.0.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@asyncapi/modelina": "^5.10.1",
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.2",
        "@faker-js/faker": "^10.4.0",
        "@prettier/plugin-oxc": "^0.1.3",
        "@stoplight/spectral-cli": "^6.15.0",
        "@stoplight/spectral-rulesets": "^1.22.0",
        "@tsconfig/node22": "^22.0.5",
        "@types/jsdom": "^28.0.0",
        "@types/node": "^25.3.5",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/coverage-v8": "^4.1.10",
        "@vitest/eslint-plugin": "^1.6.9",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.0",
        "cypress": "^15.14.2",
        "eslint": "^9.39.2",
        "eslint-plugin-cypress": "^6.1.0",
        "eslint-plugin-oxlint": "~1.51.0",
        "eslint-plugin-unicorn": "^63.0.0",
        "eslint-plugin-vue": "~10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "jsdom": "^28.1.0",
        "mermaid": "^11.15.0",
        "msw": "^2.13.4",
        "npm-check-updates": "^22.2.3",
        "npm-run-all2": "^8.0.4",
        "orval": "^8.17.0",
        "prettier": "^3.8.1",
        "sass-embedded": "^1.97.3",
        "start-server-and-test": "^2.0.10",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.2",
        "vite-plugin-vue-devtools": "^8.0.7",
        "vitepress": "^1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17",
        "vitest": "^4.0.18",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.5",
        "yaml": "^2.8.1"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
