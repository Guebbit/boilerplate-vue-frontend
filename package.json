{
  "name": "boilerplate-vue-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPLv3.0",
  "scripts": {
    "dev": "vite --port 8080",
    "build": "run-p type-check-only \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check-only": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier": "npx prettier .",
    "prettier:fix": "npx prettier . --write",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:target": "vitest run src/components/atoms/__tests__/CounterInput.spec.ts",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:target": "start-server-and-test preview http://localhost:4173 'cypress run --e2e' --spec 'tests/e2e/xxxx.spec.ts'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "kill:win": "cmd \"/C TASKKILL /IM node.exe /F\"",
    "kill:gnu": "pkill -9 node",
    "prepublish": "npm run lint && npm run test:unit && npm run build && npm run docs:build",
    "genapi": "openapi-generator-cli generate -i ./.dev/openapi.yaml -g typescript-axios -o ./src/api",
    "update:all": "npx npm-check-updates -u"
  },
  "dependencies": {
    "@guebbit/css-toolkit": "^1.3.2",
    "@guebbit/js-toolkit": "^1.0.8",
    "@guebbit/vue-toolkit": "file:../vue-toolkit/guebbit-vue-toolkit-1.0.0.tgz",
    "@openapitools/openapi-generator-cli": "^2.25.2",
    "axios": "^1.13.2",
    "minisearch": "^7.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.2",
    "vue-router": "^4.6.4",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "@eslint/js": "^9.39.2",
    "@prettier/plugin-oxc": "^0.1.3",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/eslint-plugin": "^1.5.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^9.39.2",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-oxlint": "~1.34.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-vue": "~10.6.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^15.8.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.7.4",
    "sass-embedded": "^1.97.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.16",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.0"
  }
}