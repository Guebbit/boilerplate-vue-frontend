{
    "extends": "./tsconfig.app.json",
    "include": [
        "contracts/rest",
        "src/**/*",
        "src/**/*.vue",
        "tests/unit/**/*.ts",
        "tests/unit/**/*.tsx",
        "tests/mocks/**/*",
        ".dev/**/*.ts"
    ],
    "exclude": [],
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",

        "lib": ["ESNext", "DOM"],
        "types": ["vite/client", "node", "jsdom"]
    }
}
